{
  "name": "debate-ai-web",
  "description": "Debate AI enables competitive debaters in PF, LD & Policy to streamline AI research management, live speech sharing, and evidence analysis",
  "version": "0.5.0",
  "type": "module",
  "author": "vtempest",
  "license": "rights.institute/prosper",
  "scripts": {
    "dev": "vinext dev",
    "build": "NODE_OPTIONS=\"${NODE_OPTIONS} --max-old-space-size=4096\" vinext build",
    "start": "vinext start",
    "deploy": "vinext deploy",
    "preview": "NODE_OPTIONS='--max-old-space-size=4096' vinext build && wrangler dev",
    "deploy:staging": "NODE_OPTIONS='--max-old-space-size=4096' vinext deploy --env staging",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:d1": "drizzle-kit push --config drizzle.d1.config.ts",
    "db:migrate:d1": "for f in drizzle/*.sql; do echo ''; wrangler d1 execute debate-db --remote --file=$f; done",
    "db:studio": "drizzle-kit studio",
    "favicon": "bun create favicon public/favicon-512.png public/ --overwrite"
  },
