{
  "name": "reason-editor",
  "version": "0.1.0",
  "description": "REASON research editor — a TipTap/React shell over the CardMirror ProseMirror debate-card engine (Verbatim .docx interop) wired for debate-ai.com FIAT speech docs",
  "private": true,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": "vtempest",
  "contributors": [
    "Anthony Trufanov (CardMirror engine)"
  ],
  "main": "./src/react/index.tsx",
  "types": "./src/react/index.tsx",
  "exports": {
    ".": "./src/react/index.tsx",
    "./engine": "./src/engine/index.ts",
    "./styles.css": "./src/react/styles.css"
  },
  "files": [
    "src",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "fast-xml-parser": "^4.5.0",
    "fflate": "^0.8.3",
    "jszip": "^3.10.1",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-dropcursor": "^1.8.1",
    "prosemirror-gapcursor": "^1.3.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.24.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.37.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.9.3"
  }
}
