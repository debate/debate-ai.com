{
  "name": "debate-ai",
  "private": true,
  "version": "2.2.0",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:web": "turbo dev --filter=debate-ai.com",
    "build:web": "turbo build --filter=debate-ai.com",
    "dev:editor": "turbo dev --filter=reason-editor",
    "build:editor": "turbo build --filter=reason-editor"
  },
  "devDependencies": {
    "turbo": "^2.9.9",
    "vinext": "0.0.45",
    "vite": "^8"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "docx-preview": "^0.3.7",
    "grab-url": "^1.6.22",
    "htmlparser2": "^12.0.0",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12"
  }
}
